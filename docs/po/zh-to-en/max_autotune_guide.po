msgid ""
"```python\n"
"@max_autotune(\n"
"    configs=[\n"
"        triton.Config(kwargs={'BLOCK_M': 128, 'BLOCK_N': 128, 'BLOCK_K': 32}),\n"
"    ],\n"
"    key=[\"M\", \"N\", \"K\"],\n"
"    kernel_type=\"cube\",\n"
"    num_stages=[1, 2],\n"
"    unit_flag=[True, False],\n"
"    limit_auto_multi_buffer_of_local_buffer=[\"no-limit\", \"no-l0c\"],\n"
")\n"
"@triton.jit\n"
"def matmul_kernel(...):\n"
"    ...\n"
"```\n"
msgstr ""

