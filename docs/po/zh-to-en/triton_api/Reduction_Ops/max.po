msgstr "### 2.2 Supported Specifications"

#. type: text
#: docs/zh/triton_api/Reduction_Ops/max.md:22
msgid "#### 2.2.1 DataType 支持"
msgstr "#### 2.2.1 DataType Support"

#. type: text
#: docs/zh/triton_api/Reduction_Ops/max.md:24
