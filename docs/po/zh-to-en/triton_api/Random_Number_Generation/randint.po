msgid "### 2.4 使用方法"
msgstr "### 2.4 Usage"

#. type: text
#: docs/zh/triton_api/Random_Number_Generation/randint.md:36
msgid "以下示例实现了对randint的调用（调用时生成单个随机数）："
msgstr "The following example implements a call to `randint` (generating a single random number when called):"

#. type: code
#: docs/zh/triton_api/Random_Number_Generation/randint.md:38
msgid ""
"```python\n"
"@triton.jit\n"
"def kernel_randint(x_ptr, n_rounds: tl.constexpr, N: tl.constexpr, XBLOCK: tl.constexpr):\n"
"    block_offset = tl.program_id(0) * XBLOCK\n"
"    block_size = XBLOCK if block_offset + XBLOCK <= N else N - block_offset\n"
"    for inner_idx in range(block_size):\n"
"        global_offset = block_offset + inner_idx\n"
"        rand_vals = tl.randint(5, 10 + global_offset, n_rounds) # 对每个索引生成一个随机数\n"
"        tl.store(x_ptr + global_offset, rand_vals) # 存储随机数\n"
"\n"
"y_cali = torch.zeros(shape, dtype=eval('torch.int32')).npu()\n"
"kernel_randint[ncore, 1, 1](y_cali, 10, numel, xblock)\n"
"```\n"
msgstr ""

