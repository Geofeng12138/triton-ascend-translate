#. type: text
#: docs/zh/triton_api/Random_Number_Generation/index.md:0
msgid "# 随机数生成"
msgstr "# Random Number Generation"

#. type: text
#: docs/zh/triton_api/Random_Number_Generation/index.md:2
msgid ""
"|api|简要说明|\n"
"|--|--|\n"
"|[randint4x](./randint4x.md) |给定 1 个seed 标量和 1 个offset 块，返回 4 个 int32 类型的随机块 |\n"
"|[randint](./randint.md) |给定 1 个 seed 标量和 1 个 offset 块，返回 1 个 int32 类型的随机块 |\n"
"|[rand](./rand.md)   |给定 1 个 seed 标量和 1 个 offset 块，返回 1 个在 U(0,1) 中的 float32 类型的随机块 |\n"
"|[randn](./randn.md)   |给定 1 个 seed 标量和 1 个 offset 块，返回 1 个在 N(0,1) 中的 float32 类型的随机块 |\n"
msgstr ""
"|api|Brief Description|\n"
"|--|--|\n"
"|[randint4x](./randint4x.md) |Given 1 seed scalar and 1 offset block, returns 4 random blocks of type int32|\n"
"|[randint](./randint.md) |Given 1 seed scalar and 1 offset block, returns 1 random block of type int32|\n"
"|[rand](./rand.md)   |Given 1 seed scalar and 1 offset block, returns 1 random block of type float32 in U(0,1)|\n"
"|[randn](./randn.md)   |Given 1 seed scalar and 1 offset block, returns 1 random block of type float32 in N(0,1)|\n"

