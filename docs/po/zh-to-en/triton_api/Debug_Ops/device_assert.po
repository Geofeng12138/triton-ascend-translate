#. type: text
#: docs/zh/triton_api/Debug_Ops/device_assert.md:22
msgid "### 2.3 使用方法"
msgstr "### 2.3 Usage"

#. type: code
#: docs/zh/triton_api/Debug_Ops/device_assert.md:24
msgid ""
"```python\n"
"import triton.language as tl\n"
"\n"
"@triton.jit\n"
"def basic_device_assert_example(x_ptr, BLOCK_SIZE: tl.constexpr):\n"
"    # 基本断言：检查程序ID\n"
"    pid = tl.program_id(0)\n"
"    tl.device_assert(pid >= 0, \"Program ID must be non-negative\")\n"
"\n"
"    offsets = tl.arange(0, BLOCK_SIZE)\n"
"    x = tl.load(x_ptr + offsets)\n"
"\n"
"    # 检查数据有效性（比如检查张量中没有负值）\n"
"    tl.device_assert(tl.min(x) >= 0, \"All values must be non-negative\")\n"
"```\n"
msgstr ""

