msgstr "When `bind_sub_block` is true, the difference from `range` is reflected in the IR; whether the functionality is implemented remains to be verified."

#. type: text
#: docs/zh/triton_api/Extension_Ops/parallel.md:26
msgid "## 3. 使用方法"
msgstr "## 3. Usage"

#. type: code
#: docs/zh/triton_api/Extension_Ops/parallel.md:28
msgid ""
"```python\n"
"@triton.jit\n"
"def parallel_kernel(\n"
"    input_ptr,\n"
"    output_ptr0,\n"
"    output_ptr1,\n"
"    pd_ptr,\n"
"    n_elements : tl.constexpr,\n"
"):\n"
"    x = tl.arange(0,n_elements)\n"
"    x0 = x // 4\n"
"    x1 = x % 4\n"
"\n"
"    a_ptr = input_ptr + x0\n"
"    b_ptr = input_ptr + x0\n"
"    for i in tl.parallel(0, 3, 1, bind_sub_block = False):\n"
"        a_ptr += x0\n"
"        b_ptr += x0\n"
"    a_ptr += x1\n"
"    b_ptr += x1\n"
"    val = tl.load(a_ptr + 0)\n"
"    tl.store(output_ptr0 + x,val)\n"
"    val = tl.load(b_ptr)\n"
"    tl.store(output_ptr1 + x,val)\n"
"```\n"
msgstr ""

