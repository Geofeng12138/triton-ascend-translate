msgstr "No special restrictions."

#. type: text
#: docs/zh/triton_api/Extension_Ops/extract_slice.md:30
msgid "### 2.4 使用方法"
msgstr "### 2.4 Usage"

#. type: text
#: docs/zh/triton_api/Extension_Ops/extract_slice.md:32
msgid "以下示例实现了从计算结果中提取前32个元素："
msgstr "The following example extracts the first 32 elements from the computation result:"

#. type: code
#: docs/zh/triton_api/Extension_Ops/extract_slice.md:34
msgid ""
"```python\n"
"@triton.jit\n"
"def triton_kernel(x_ptr, y_ptr, output_ptr, n_elements, BLOCK_SIZE: tl.constexpr):\n"
"    pid = tl.program_id(axis=0)\n"
"    block_start = pid * BLOCK_SIZE\n"
"    offsets = block_start + tl.arange(0, BLOCK_SIZE)\n"
"    mask = offsets < n_elements\n"
"    x = tl.load(x_ptr + offsets, mask=mask)\n"
"    y = tl.load(y_ptr + offsets, mask=mask)\n"
"    output = x + y\n"
"    # 提取前32个元素\n"
"    out_sub = tl.extract_slice(output, [block_start], [32], [1])\n"
"    out_idx = block_start + tl.arange(0, 32)\n"
"    out_msk = out_idx < n_elements\n"
"    tl.store(output_ptr + out_idx, out_sub, mask=out_msk)\n"
"```\n"
msgstr ""

