#. type: text
#: docs/zh/triton_api/Comparing_Ops/lt.md:38
msgid "### 2.4 使用方法"
msgstr "### 2.4 Usage"

#. type: text
#: docs/zh/triton_api/Comparing_Ops/lt.md:40
msgid "以下示例实现了对三维张量`x0`、`x1`做小于运算："
msgstr "The following example implements a less-than operation on the three-dimensional tensors `x0` and `x1`:"

#. type: code
#: docs/zh/triton_api/Comparing_Ops/lt.md:42
msgid ""
"```python\n"
"@triton.jit\n"
"def triton_lt_3d(in_ptr0, in_ptr1, out_ptr0, L: tl.constexpr, M: tl.constexpr, N: tl.constexpr):\n"
"    lblk_idx = tl.arange(0, L)\n"
"    mblk_idx = tl.arange(0, M)\n"
"    nblk_idx = tl.arange(0, N)\n"
"    idx = lblk_idx[:, None, None] * N * M + mblk_idx[None, :, None] * N + nblk_idx[None, None, :]\n"
"    x0 = tl.load(in_ptr0 + idx)\n"
"    x1 = tl.load(in_ptr1 + idx)\n"
"    ret = x0 < x1\n"
"    odx = lblk_idx[:, None, None] * N * M + mblk_idx[None, :, None] * N + nblk_idx[None, None, :]\n"
"    tl.store(out_ptr0 + odx, ret)\n"
"```\n"
msgstr ""

