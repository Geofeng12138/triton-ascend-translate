#. type: text
#: docs/zh/triton_api/Shape_Manipulation_Ops/trans.md:32
msgid "### 2.3 Shape支持表"
msgstr "### 2.3 Shape Support Table"

#. type: text
#: docs/zh/triton_api/Shape_Manipulation_Ops/trans.md:34
msgid "支持任意维度数、任意形状大小。"
msgstr "Supports any number of dimensions and any shape size."

#. type: text
#: docs/zh/triton_api/Shape_Manipulation_Ops/trans.md:36
msgid "### 2.4 特殊限制说明"
msgstr "### 2.4 Special Restrictions Explanation"

#. type: text
#: docs/zh/triton_api/Shape_Manipulation_Ops/trans.md:38
msgid "* 不支持维度高于8的转置"
msgstr "* Transpose for dimensions higher than 8 is not supported"

#. type: text
#: docs/zh/triton_api/Shape_Manipulation_Ops/trans.md:40
msgid "### 2.5 使用方法"
msgstr "### 2.5 Usage"

#. type: code
#: docs/zh/triton_api/Shape_Manipulation_Ops/trans.md:42
msgid ""
"```python\n"
"import triton\n"
"import triton.language as tl\n"
"\n"
"@triton.jit\n"
"def trans_example():\n"
"    # 创建2x3x4的张量\n"
"    x = tl.zeros([2, 3, 4], dtype=tl.float32)\n"
"\n"
"    # 转置维度，变成4x2x3\n"
"    y = tl.trans(x, [2, 0, 1])\n"
"\n"
"    return y\n"
"\n"
"## 调用示例\n"
"result = trans_example()\n"
"print(result.shape)  # 输出: (4, 2, 3)\n"
"```\n"
msgstr ""

