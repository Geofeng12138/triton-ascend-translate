#. type: text
#: docs/zh/triton_api/Shape_Manipulation_Ops/view.md:32
msgid "### 2.3 Shape支持表"
msgstr "### 2.3 Shape Support Table"

#. type: text
#: docs/zh/triton_api/Shape_Manipulation_Ops/view.md:34
msgid "支持任意维度数、任意形状大小。"
msgstr "Supports any number of dimensions and any shape size."

#. type: text
#: docs/zh/triton_api/Shape_Manipulation_Ops/view.md:36
msgid "### 2.4 特殊限制说明"
msgstr "### 2.4 Special Restrictions Explanation"

#. type: text
#: docs/zh/triton_api/Shape_Manipulation_Ops/view.md:38
msgid "无"
msgstr "None"

#. type: text
#: docs/zh/triton_api/Shape_Manipulation_Ops/view.md:40
msgid "### 2.5 使用方法"
msgstr "### 2.5 Usage"

#. type: code
#: docs/zh/triton_api/Shape_Manipulation_Ops/view.md:42
msgid ""
"```python\n"
"import torch\n"
"import triton\n"
"import triton.language as tl\n"
"\n"
"@triton.jit\n"
"def view_example(out_ptr):\n"
"    # 创建2x3x4的张量\n"
"    x = tl.zeros([2, 3, 4], dtype=tl.float32)\n"
"\n"
"    # 创建视图，变成6x4\n"
"    y = tl.view(x, [6, 4])\n"
"\n"
"    # 将结果写回外部张量\n"
"    offs = tl.arange(0, 6)[:, None] * 4 + tl.arange(0, 4)[None, :]\n"
"    tl.store(out_ptr + offs, y)\n"
"\n"
"## 调用示例\n"
"out = torch.empty((6, 4), dtype=torch.float32, device=\"npu\")\n"
"view_example[(1,)](out)\n"
"print(out.shape)  # 输出: torch.Size([6, 4])\n"
"```\n"
msgstr ""

