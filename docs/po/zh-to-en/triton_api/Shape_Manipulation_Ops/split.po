#: docs/zh/triton_api/Shape_Manipulation_Ops/split.md:38
msgid "无"
msgstr "None"

#. type: text
#: docs/zh/triton_api/Shape_Manipulation_Ops/split.md:40
msgid "### 2.5 使用方法"
msgstr "### 2.5 Usage"

#. type: code
#: docs/zh/triton_api/Shape_Manipulation_Ops/split.md:42
msgid ""
"```python\n"
"@triton.jit\n"
"def complex_split_kernel(complex_ptr, real_ptr, imag_ptr, M, N, BLOCK_M: tl.constexpr, BLOCK_N: tl.constexpr):\n"
"    # 加载复数数据\n"
"    complex_data = tl.load(complex_ptr + offsets, mask=mask)\n"
"\n"
"    # 分割成实部和虚部\n"
"    real_part, imag_part = complex_data.split()\n"
"\n"
"    # 存储实部和虚部\n"
"    tl.store(real_ptr + offsets, real_part, mask=mask)\n"
"    tl.store(imag_ptr + offsets, imag_part, mask=mask)\n"
"```\n"
msgstr ""

