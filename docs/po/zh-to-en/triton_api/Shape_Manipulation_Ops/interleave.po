#. type: text
#: docs/zh/triton_api/Shape_Manipulation_Ops/interleave.md:32
msgid "### 2.3 Shape支持表"
msgstr "### 2.3 Shape Support Table"

#. type: text
#: docs/zh/triton_api/Shape_Manipulation_Ops/interleave.md:34
msgid "支持任意维度数、任意形状大小。"
msgstr "Supports any number of dimensions and any shape size."

#. type: text
#: docs/zh/triton_api/Shape_Manipulation_Ops/interleave.md:36
msgid "### 2.4 特殊限制说明"
msgstr "### 2.4 Special Limitations"

#. type: text
#: docs/zh/triton_api/Shape_Manipulation_Ops/interleave.md:38
msgid "无"
msgstr "None"

#. type: text
#: docs/zh/triton_api/Shape_Manipulation_Ops/interleave.md:40
msgid "### 2.5 使用方法"
msgstr "### 2.5 Usage"

#. type: code
#: docs/zh/triton_api/Shape_Manipulation_Ops/interleave.md:42
msgid ""
"```python\n"
"import triton\n"
"import triton.language as tl\n"
"\n"
"@triton.jit\n"
"def interleave_example():\n"
"    # 创建两个2x3的张量\n"
"    x = tl.zeros([2, 3], dtype=tl.float32)\n"
"    y = tl.ones([2, 3], dtype=tl.float32)\n"
"\n"
"    # 交错排列，变成2x6\n"
"    z = tl.interleave(x, y)\n"
"\n"
"    return z\n"
"\n"
"## 调用示例\n"
"result = interleave_example()\n"
"print(result.shape)  # 输出: (2, 6)\n"
"```\n"
msgstr ""

