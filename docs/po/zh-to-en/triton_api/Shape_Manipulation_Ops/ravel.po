#. type: text
#: docs/zh/triton_api/Shape_Manipulation_Ops/ravel.md:40
msgid "### 2.5 使用方法"
msgstr "### 2.5 Usage"

#. type: code
#: docs/zh/triton_api/Shape_Manipulation_Ops/ravel.md:42
msgid ""
"```python\n"
"@triton.jit\n"
"def flatten_kernel(x_ptr, output_ptr, M, N, BLOCK_SIZE: tl.constexpr):\n"
"    # 加载2D数据\n"
"    x = tl.load(x_ptr + offsets, mask=mask)\n"
"\n"
"    # 展平为一维\n"
"    x_flat = x.ravel()\n"
"\n"
"    # 存储展平结果\n"
"    tl.store(output_ptr + offsets, x_flat, mask=mask)\n"
"```\n"
msgstr ""

