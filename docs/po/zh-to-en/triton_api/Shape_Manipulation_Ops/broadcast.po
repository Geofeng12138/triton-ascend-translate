#. type: text
#: docs/zh/triton_api/Shape_Manipulation_Ops/broadcast.md:36
msgid "### 2.5 使用方法"
msgstr "### 2.5 Usage"

#. type: text
#: docs/zh/triton_api/Shape_Manipulation_Ops/broadcast.md:38
msgid "**基本用法：**"
msgstr "**Basic Usage:**"

#. type: code
#: docs/zh/triton_api/Shape_Manipulation_Ops/broadcast.md:40
msgid ""
"```python\n"
"@triton.jit\n"
"def broadcast_kernel(\n"
"    output_ptr,\n"
"    BLOCK_SIZE: tl.constexpr\n"
"):\n"
"    # 创建一个标量（0维张量）\n"
"    scalar = 5.0\n"
"\n"
"    # 创建一个向量（1维张量）\n"
"    vector = tl.arange(0, BLOCK_SIZE) * 1.0  # 形状: (BLOCK_SIZE,)\n"
"\n"
"    # 使用 broadcast 将标量广播到与向量相同的形状\n"
"    # scalar: () -> (BLOCK_SIZE,)\n"
"    broadcasted_scalar = tl.broadcast(scalar, vector)\n"
"\n"
"    result = vector + broadcasted_scalar\n"
"\n"
"    # 存储结果\n"
"    offsets = tl.arange(0, BLOCK_SIZE)\n"
"    tl.store(output_ptr + offsets, result)\n"
"\n"
"```\n"
msgstr ""

