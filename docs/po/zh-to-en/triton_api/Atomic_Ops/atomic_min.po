"| scope | Accepted values are \"gpu\", \"cta\", or \"sys\".<br>We only support \"gpu\". |\n"

#. type: text
#: docs/zh/triton_api/Atomic_Ops/atomic_min.md:36
msgid "### 2.4 使用方法"
msgstr "### 2.4 Usage"

#. type: text
#: docs/zh/triton_api/Atomic_Ops/atomic_min.md:38
msgid "以下示例实现了原子取最小值计算："
msgstr "The following example implements atomic minimum value calculation:"

#. type: code
#: docs/zh/triton_api/Atomic_Ops/atomic_min.md:40
msgid ""
"```python\n"
"@triton.jit\n"
"def triton_atomic_min(\n"
"    in_ptr0, out_ptr0, n_elements: tl.constexpr, BLOCK_SIZE: tl.constexpr\n"
"):\n"
"    xoffset = tl.program_id(0) * BLOCK_SIZE\n"
"    xindex = xoffset + tl.arange(0, BLOCK_SIZE)[:]\n"
"    yindex = xoffset + tl.arange(0, BLOCK_SIZE)[:]\n"
"    xmask = xindex < n_elements\n"
"    x0 = xindex\n"
"    x1 = yindex\n"
"    tmp0 = tl.load(in_ptr0 + (x0), xmask)\n"
"    tmp1 = tl.atomic_min(out_ptr0 + (x1), tmp0, xmask)\n"
"```\n"
msgstr ""

