#: docs/zh/triton_api/Creation_Ops/zeros_like.md:30
msgid "### 2.4 使用方法"
msgstr "### 2.4 Usage"

#. type: text
#: docs/zh/triton_api/Creation_Ops/zeros_like.md:32
msgid "以下示例实现了返回与给定张量具有相同形状和类型的零的张量。："
msgstr "The following example returns a tensor of zeros with the same shape and type as the given tensor."

#. type: code
#: docs/zh/triton_api/Creation_Ops/zeros_like.md:34
msgid ""
"```python\n"
"@triton.jit\n"
"def fn_npu_(output_ptr, x_ptr, XB: tl.constexpr, YB: tl.constexpr, ZB: tl.constexpr):\n"
"    xidx = tl.arange(0, XB)\n"
"    yidx = tl.arange(0, YB)\n"
"    zidx = tl.arange(0, ZB)\n"
"\n"
"    idx = xidx[:, None, None] * YB * ZB + yidx[None, :, None] * ZB + zidx[None, None, :]\n"
"\n"
"    X = tl.load(x_ptr + idx)\n"
"\n"
"    ret = tl.zeros_like(X)\n"
"\n"
"    oidx = xidx[:, None, None] * YB * ZB + yidx[None, :, None] * ZB + zidx[None, None, :]\n"
"\n"
"    tl.store(output_ptr + oidx, ret)\n"
"\n"
"```\n"
msgstr ""

