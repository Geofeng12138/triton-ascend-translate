#. type: text
#: docs/zh/triton_api/Creation_Ops/cast.md:40
msgid "### 2.5 使用方法"
msgstr "### 2.5 Usage"

#. type: text
#: docs/zh/triton_api/Creation_Ops/cast.md:42
msgid "**基本用法：**"
msgstr "**Basic Usage:**"

#. type: code
#: docs/zh/triton_api/Creation_Ops/cast.md:44
msgid ""
"```python\n"
"import triton\n"
"import triton.language as tl\n"
"\n"
"@triton.jit\n"
"def cast_example():\n"
"    # 创建float32张量\n"
"    x = tl.zeros([2, 3], dtype=tl.float32)\n"
"\n"
"    # 转换为int32\n"
"    y = tl.cast(x, tl.int32)\n"
"\n"
"    return y\n"
"\n"
"## 调用示例\n"
"result = cast_example()\n"
"print(result.dtype)  # 输出: int32\n"
"```\n"
msgstr ""

#. type: text
#: docs/zh/triton_api/Creation_Ops/cast.md:46
msgid "**高级用法：**"
msgstr "**Advanced Usage:**"

#. type: code
#: docs/zh/triton_api/Creation_Ops/cast.md:48
msgid ""
"```python\n"
"@triton.jit\n"
"def cast_advanced_example():\n"
"    # 创建float32张量\n"
"    x = tl.zeros([2, 3], dtype=tl.float32)\n"
"\n"
"    # 位级别重解释\n"
"    y = x.cast(tl.int32, bitcast=True)\n"
"\n"
"    # 浮点降精度，向零舍入\n"
"    z = x.cast(tl.float16, fp_downcast_rounding=\"rtz\")\n"
"\n"
"    # float32 → int8，启用饱和模式（Ascend 扩展，超出 int8 范围的值会被截断到 [-128, 127]）\n"
"    w = x.cast(tl.int8, overflow_mode=\"saturate\")\n"
"\n"
"    return y, z, w\n"
"```\n"
msgstr ""

#. type: text
#: docs/zh/triton_api/Creation_Ops/cast.md:50
msgid "**实际应用场景：**"
msgstr "**Practical Application Scenarios:**"

#. type: code
#: docs/zh/triton_api/Creation_Ops/cast.md:52
msgid ""
"```python\n"
"@triton.jit\n"
"def quantization_kernel(x_ptr, output_ptr, scale, zero_point, M, N, BLOCK_M: tl.constexpr, BLOCK_N: tl.constexpr):\n"
"    # 加载float32数据\n"
"    x = tl.load(x_ptr + offsets, mask=mask)\n"
"\n"
"    # 量化：转换为int8\n"
"    x_quantized = tl.cast(x * scale + zero_point, tl.int8, overflow_mode=\"saturate\")\n"
"\n"
"    # 存储量化结果\n"
"    tl.store(output_ptr + offsets, x_quantized, mask=mask)\n"
"```\n"
msgstr ""

