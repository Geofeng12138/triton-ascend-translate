#: docs/zh/triton_api/Math_Ops/sub.md:26
msgid "### 2.3 дљњзФ®жЦєж≥Х"
msgstr "### 2.3 Usage"

#. type: text
#: docs/zh/triton_api/Math_Ops/sub.md:28
msgid "дї•дЄЛз§ЇдЊЛеЃЮзО∞дЇЖеѓєиЊУеЕ•еЉ†йЗП `in_ptr0, in_ptr1` еБЪеЗПж≥ХиЃ°зЃЧпЉЪ"
msgstr "The following example implements subtraction on the input tensors `in_ptr0, in_ptr1`:"

#. type: code
#: docs/zh/triton_api/Math_Ops/sub.md:30
msgid ""
"```python\n"
"@triton.jit\n"
"def triton_sub(in_ptr0, in_ptr1, out_ptr0, XBLOCK: tl.constexpr, XBLOCK_SUB: tl.constexpr):\n"
"    offset = tl.program_id(0) * XBLOCK\n"
"    base1 = tl.arange(0, XBLOCK_SUB)\n"
"    loops1: tl.constexpr = (XBLOCK + XBLOCK_SUB - 1) // XBLOCK_SUB\n"
"    for loop1 in range(loops1):\n"
"        x0_prime = offset + (loop1 * XBLOCK_SUB) + base1\n"
"        x0 = offset + (loop1 * XBLOCK_SUB) + base1\n"
"        tmp0 = tl.load(in_ptr0 + (x0), None)\n"
"        tmp1 = tl.load(in_ptr1 + (x0), None)\n"
"        tmp2 = tmp0 - tmp1\n"
"        tl.store(out_ptr0 + (x0), tmp2, None)\n"
"```\n"
msgstr ""

