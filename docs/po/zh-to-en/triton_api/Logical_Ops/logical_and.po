#. type: text
#: docs/zh/triton_api/Logical_Ops/logical_and.md:38
msgid "### 2.4 使用方法"
msgstr "### 2.4 Usage"

#. type: text
#: docs/zh/triton_api/Logical_Ops/logical_and.md:40
msgid "以下示例实现了对三维张量`x0`、`x1`做逻辑与运算："
msgstr "The following example implements the logical AND operation on three-dimensional tensors `x0` and `x1`:"

#. type: code
#: docs/zh/triton_api/Logical_Ops/logical_and.md:42
msgid ""
"```python\n"
"@triton.jit\n"
"def triton_logical_and_3d(in_ptr0, in_ptr1, out_ptr0, XB, YB, ZB, L: tl.constexpr, M: tl.constexpr, N: tl.constexpr):\n"
"    lblk_idx = tl.arange(0, L) + tl.program_id(0) * XB\n"
"    mblk_idx = tl.arange(0, M) + tl.program_id(1) * YB\n"
"    nblk_idx = tl.arange(0, N) + tl.program_id(2) * ZB\n"
"    idx = lblk_idx[:, None, None] * N * M + mblk_idx[None, :, None] * N + nblk_idx[None, None, :]\n"
"    x0 = tl.load(in_ptr0 + idx)\n"
"    x1 = tl.load(in_ptr1 + idx)\n"
"    ret = x0.logical_and(x1)\n"
"    odx = lblk_idx[:, None, None] * N * M + mblk_idx[None, :, None] * N + nblk_idx[None, None, :]\n"
"    tl.store(out_ptr0 + odx, ret)\n"
"```\n"
msgstr ""

